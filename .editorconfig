root = true

[*]
indent_style = space
indent_size = 2
end_of_line = lf
charset = utf-8
trim_trailing_whitespace = true
insert_final_newline = true

[*.md]
trim_trailing_whitespace = false

[*.{ts,tsx,js,mjs,cjs,jsx}]
quote_type = double

[*.yml]
indent_size = 2

[*.ps1]
indent_style = space
indent_size = 4
end_of_line = crlf
